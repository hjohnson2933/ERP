# Same Supabase project the mill list app uses — get these from the
# Supabase dashboard under Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side only, never exposed to the browser.
# Needed for any ERP server action that must bypass RLS (e.g. system jobs).
SUPABASE_SERVICE_ROLE_KEY=
